<?xml version="1.0" encoding="utf-8"?>
<!--
  BISTAI Splash Screen İkonu (V1.3)
  Android 12+ windowSplashScreenAnimatedIcon için özel ikon.
  Bu ikon dairesel kırpılır → 108dp içinde merkez 72dp (27-81 arası) güvenli.
  Tasarım: Sadece trend oku + "B" baş harfi — metin yok, kırpılma sorusu yok.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Lacivert daire arka plan -->
    <path
        android:fillColor="#112240"
        android:pathData="M54,54 m-48,0 a48,48 0 1,0 96,0 a48,48 0 1,0 -96,0"/>

    <!-- Büyük "B" harfi — merkez, beyaz -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M34,28 L34,80 L40,80 L40,28 Z"/>
    <!-- B üst yuvarlak -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M40,28 L56,28 Q70,28 70,41 Q70,54 56,54 L40,54 Z
                          M40,30 L55,30 Q66,30 66,41 Q66,52 55,52 L40,52 Z"/>
    <!-- B alt yuvarlak (biraz daha geniş) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M40,54 L58,54 Q74,54 74,67 Q74,80 58,80 L40,80 Z
                          M40,56 L57,56 Q70,56 70,67 Q70,78 57,78 L40,78 Z"/>

    <!-- Yeşil trend oku — sağ üst (güvenli alanda) -->
    <path
        android:strokeColor="#00C853"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M62,72 L68,60 L73,66 L80,48"/>
    <!-- Ok ucu -->
    <path
        android:fillColor="#00C853"
        android:pathData="M80,48 L74,52 L77,58 Z"/>

    <!-- Altın alt çizgi -->
    <path
        android:strokeColor="#FFC107"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M34,84 L80,84"/>

</vector>
